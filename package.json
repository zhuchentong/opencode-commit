{
	"name": "@gopowerteam/opencode-commit",
	"version": "0.0.12",
	"description": "OpenCode 插件 - 根据 Git 变更自动生成中文约定式提交信息",
	"keywords": [
		"opencode",
		"opencode-plugin",
		"plugin"
	],
	"license": "MIT",
	"files": [
		"dist"
	],
	"type": "module",
	"main": "dist/index.js",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"dev": "bun run scripts/dev.ts",
		"build": "bun run scripts/build.ts",
		"typecheck": "tsc --noEmit",
		"release": "bumpp"
	},
	"bumpp": {
		"commit": "chore: release v%s",
		"tag": "v%s",
		"push": true,
		"execute": "bun run build && npm publish"
	},
	"peerDependencies": {
		"@opencode-ai/plugin": ">=1.0.0"
	},
	"devDependencies": {
		"@opencode-ai/plugin": "^1.14.48",
		"@opencode-ai/sdk": "^1.14.48",
		"@types/bun": "^1.3.8",
		"bumpp": "^11.1.0",
		"typescript": "^5.7.2"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gopowerteam/opencode-commit.git"
	},
	"homepage": "https://github.com/gopowerteam/opencode-commit#readme",
	"publishConfig": {
		"access": "public"
	},
	"packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
