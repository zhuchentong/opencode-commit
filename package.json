{
	"name": "opencode-commit",
	"version": "0.0.3",
	"description": "OpenCode 插件 - 根据 Git 变更自动生成中文约定式提交信息",
	"keywords": ["opencode", "opencode-plugin", "plugin"],
	"license": "MIT",
	"files": ["dist"],
	"type": "module",
	"main": "dist/index.js",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"dev": "bun run scripts/dev.ts",
		"build": "bun run scripts/build.ts",
		"typecheck": "tsc --noEmit",
		"release": "bumpp"
	},
	"bumpp": {
		"commit": "chore: release v%s",
		"tag": "v%s",
		"push": true,
		"execute": "bun run build && npm publish"
	},
	"peerDependencies": {
		"@opencode-ai/plugin": ">=1.0.0"
	},
	"devDependencies": {
		"@opencode-ai/plugin": "^1.14.48",
		"@opencode-ai/sdk": "^1.14.48",
		"@types/bun": "^1.3.8",
		"bumpp": "^11.1.0",
		"typescript": "^5.7.2"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zhuchentong/opencode-commit.git"
	},
	"homepage": "https://github.com/zhuchentong/opencode-commit#readme"
}
